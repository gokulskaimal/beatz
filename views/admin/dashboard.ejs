<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Beatz</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-black text-white">
  <!-- Sidebar and Header -->
  <div class="flex">
    <!-- Sidebar -->
    <div class="w-64 bg-[#111] p-4">
      <div class="mb-8">
        <h1 class="text-2xl font-bold">
          <span class="text-orange-500">b</span>eatz
        </h1>
      </div>
      <nav class="space-y-2">
        <% const navItems = [
            { icon: 'bar-chart-3', text: 'Dashboard' },
            { icon: 'box', text: 'Products' },
            { icon: 'users', text: 'Customers' },
            { icon: 'shopping-cart', text: 'Orders' },
            { icon: 'gift', text: 'Coupons' },
            { icon: 'layout-grid', text: 'Category' },
            { icon: 'percent', text: 'Discounts' },
            { icon: 'package', text: 'Banner' },
            { icon: 'bar-chart-3', text: 'Sales Report' }
        ] %>
        <% navItems.forEach(item => { %>
            <button class="w-full flex justify-start items-center gap-2 px-4 py-2 text-gray-300 hover:text-white hover:bg-[#222] rounded-md transition-colors duration-200">
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
                <%= item.text %>
            </button>
        <% }) %>
        <button class="w-full flex justify-start items-center gap-2 px-4 py-2 text-red-500 hover:text-red-400 hover:bg-[#222] rounded-md transition-colors duration-200">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Logout
        </button>
      </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-1 bg-gray-800 p-6">
      <!-- Header -->
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-xl font-bold text-yellow-500">Sales Summary</h1>
        <button class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-400">Download</button>
      </div>

      <!-- Summary Cards -->
      <div class="grid grid-cols-4 gap-4 mb-6">
        <div class="p-4 bg-gray-700 rounded-lg text-center">
          <h2 class="text-white font-bold">40,689</h2>
          <p class="text-gray-400 text-sm">Total Users</p>
          <p class="text-green-500 text-xs">+8.5% Up from yesterday</p>
        </div>
        <div class="p-4 bg-gray-700 rounded-lg text-center">
          <h2 class="text-white font-bold">10,293</h2>
          <p class="text-gray-400 text-sm">Total Orders</p>
          <p class="text-green-500 text-xs">+1.3% Up from past week</p>
        </div>
        <div class="p-4 bg-gray-700 rounded-lg text-center">
          <h2 class="text-white font-bold">₹99,000</h2>
          <p class="text-gray-400 text-sm">Total Sales</p>
          <p class="text-red-500 text-xs">-4.3% Down from yesterday</p>
        </div>
        <div class="p-4 bg-gray-700 rounded-lg text-center">
          <h2 class="text-white font-bold">2,040</h2>
          <p class="text-gray-400 text-sm">Total Customers</p>
          <p class="text-green-500 text-xs">+1.6% Up from yesterday</p>
        </div>
      </div>

      <!-- Chart Section -->
      <div class="bg-gray-700 rounded-lg p-4">
        <h3 class="text-yellow-500 text-lg font-bold mb-4">Orders Update</h3>
        <canvas id="orderChart" class="w-full h-64"></canvas>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('orderChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
        datasets: [{
          label: 'Orders',
          data: [500, 700, 1000, 800, 1200, 1500, 1700, 2000, 2200, 1800, 1900, 2300],
          borderColor: '#F59E0B',
          borderWidth: 2,
          fill: false
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: { beginAtZero: true }
        }
      }
    });
  </script>
</body>
</html>
