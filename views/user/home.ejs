<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beatz Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        orange: {
                            500: "#f97316",
                            600: "#ea580c",
                        },
                    },
                },
            },
        };
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .bg-darker {
                background-color: #0a0a0a;
            }
        }
    </style>
</head>

<body class="min-h-screen bg-black text-white">
    <!-- Include Header -->
    <%- include('../partials/header') %>

        <main>
            <!-- Hero Section -->
            <section class="relative h-[500px] overflow-hidden">
                <img src="/images/hphero-kimkpill.jpg.large.2x.jpg" alt="Beats x Kim"
                    class="object-cover w-full h-full">
                <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-transparent">
                    <div class="container mx-auto px-4 h-full flex items-center">
                        <div class="max-w-lg">
                            <h1 class="text-5xl font-bold mb-4">
                                beats <span class="text-orange-500">x</span> kim
                            </h1>
                            <p class="text-gray-300 mb-6">Special Edition Beats Pro</p>
                            <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded">
                                Shop Now
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- New Products Section -->
            <section class="py-12 bg-darker">
                <div class="container mx-auto px-4">
                    <h2 class="text-2xl font-bold text-orange-500 mb-8">New Arrivals</h2>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        <% products.forEach((product, index)=> { %>
                            <div
                                class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
                                <a href="/user/product/<%= product._id %>">
                                    <div class="relative group">
                                        <img src="<%= product.image[0] %>" alt="<%= product.product_name %>"
                                            class="w-full h-60 object-cover group-hover:scale-105 transition-transform duration-300">
                                        <div
                                            class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                        </div>
                                    </div>
                                    <div class="p-4">
                                        <h3 class="font-semibold text-lg text-white mb-1">
                                            <%= product.product_name %>
                                        </h3>
                                        <div class="flex items-center gap-1 mb-2">
                                            <span class="text-yellow-400">
                                                &#9733;&#9733;&#9733;&#9733;&#9734;
                                            </span>
                                            <span class="text-gray-400 text-sm">(120 Reviews)</span>
                                        </div>
                                        <p class="text-white-500 font-bold text-xl mb-4"><span class="text-red-500 font-bold">₹</span><%= product.price %>
                                        </p>
                                        <button
                                            class="w-full bg-yellow-500 hover:bg-yellow-800 text-black font-bold px-4 py-2 rounded-lg font-medium transition duration-300">
                                            Add to Cart
                                        </button>
                                    </div>
                                </a>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </section>



            <!-- Featured Product -->
