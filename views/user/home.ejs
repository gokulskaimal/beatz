<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beatz Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        orange: {
                            500: "#f97316",
                            600: "#ea580c",
                        },
                    },
                },
            },
        };
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .bg-darker {
                background-color: #0a0a0a;
            }
        }
    </style>
</head>
<body class="min-h-screen bg-black text-white">
      <!-- Include Header -->
  <%- include('../partials/header') %>

    <main>
        <!-- Hero Section -->
        <section class="relative h-[500px] overflow-hidden">
            <img src="/placeholder.svg?height=500&width=1920" alt="Beats x Kim" class="object-cover w-full h-full">
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-transparent">
                <div class="container mx-auto px-4 h-full flex items-center">
                    <div class="max-w-lg">
                        <h1 class="text-5xl font-bold mb-4">
                            beats <span class="text-orange-500">x</span> kim
                        </h1>
                        <p class="text-gray-300 mb-6">Special Edition Beats Pro</p>
                        <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded">
                            Shop Now
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- New Products -->
        <section class="py-12 bg-darker">
            <div class="container mx-auto px-4">
                <h2 class="text-2xl font-bold mb-8">New Products</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <% for (let i = 0; i < 4; i++) { %>
                        <div class="bg-gray-900 border-gray-800 rounded-lg overflow-hidden">
                            <div class="p-4">
                                <img src="/placeholder.svg?height=200&width=200" alt="Beats Solo Pro" class="w-full h-auto mb-4">
                                <h3 class="font-semibold mb-2">Beats Solo Pro</h3>
                                <p class="text-gray-400 text-sm mb-2">$299.99</p>
                                <button class="w-full border border-gray-600 text-white px-4 py-2 rounded hover:bg-gray-800">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Featured Product -->
        <section class="py-12 bg-black">
            <div class="container mx-auto px-4">
                <div class="flex flex-col md:flex-row items-center gap-8">
                    <div class="flex-1">
                        <h2 class="text-4xl font-bold mb-4">Beats Solo 4</h2>
                        <p class="text-gray-400 mb-6">Stands out. Stays on.</p>
                        <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded">
                            Learn More
                        </button>
                    </div>
                    <div class="flex-1">
                        <img src="/placeholder.svg?height=400&width=600" alt="Beats Solo 4" class="rounded-lg w-full h-auto">
                    </div>
                </div>
            </div>
        </section>

        <!-- More Products -->
        <section class="py-12 bg-darker">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <% for (let i = 0; i < 4; i++) { %>
                        <div class="bg-gray-900 border-gray-800 rounded-lg overflow-hidden">
                            <div class="p-4">
                                <img src="/placeholder.svg?height=200&width=200" alt="Beats Solo Pro" class="w-full h-auto mb-4">
                                <h3 class="font-semibold mb-2">Beats Solo Pro</h3>
                                <p class="text-gray-400 text-sm mb-2">$299.99</p>
                                <button class="w-full border border-gray-600 text-white px-4 py-2 rounded hover:bg-gray-800">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Registration -->
        <section class="py-12 bg-black">
            <div class="container mx-auto px-4">
                <div class="max-w-md mx-auto text-center">
                    <h2 class="text-2xl font-bold mb-4">Register your Beats</h2>
                    <p class="text-gray-400 mb-6">
                        Register your Beats product for warranty and updates
                    </p>
                    <div class="flex gap-2">
                        <input type="text" placeholder="Enter serial number" class="flex-1 bg-gray-900 border-gray-800 text-white px-3 py-2 rounded">
                        <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded">
                            Register
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
      <!-- Include Footer -->
  <%- include('../partials/footer') %>
</body>
</html>